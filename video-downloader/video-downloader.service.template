[Unit]
Description=Video Downloader FastAPI Service
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/video-downloader
Environment="CORS_ALLOW_ORIGINS=https://ai-copywriting-beautification-program.pages.dev"
ExecStart=/opt/video-downloader/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
